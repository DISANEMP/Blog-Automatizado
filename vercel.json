{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "config/**",
          "scripts/**",
          "assets/**"
        ]
      }
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/veredito/config",
      "dest": "/api/veredito/config.js"
    },
    {
      "src": "/api/veredito/preview",
      "dest": "/api/veredito/preview.js"
    },
    {
      "src": "/api/veredito/publish",
      "dest": "/api/veredito/publish.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/posts/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "max-image-preview:large"
        }
      ]
    }
  ]
}
