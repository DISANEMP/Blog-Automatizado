{
  "version": 2,
  "builds": [
    {
      "src": "api/veredito/*.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "api/_lib/**",
          "config/**",
          "scripts/**",
          "assets/**"
        ]
      }
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/veredito/config",
      "dest": "/api/veredito/config.js"
    },
    {
      "src": "/api/veredito/generate",
      "dest": "/api/veredito/generate.js"
    },
    {
      "src": "/api/veredito/generate-from-url",
      "dest": "/api/veredito/generate-from-url.js"
    },
    {
      "src": "/api/veredito/drafts",
      "dest": "/api/veredito/drafts.js"
    },
    {
      "src": "/api/veredito/article",
      "dest": "/api/veredito/article.js"
    },
    {
      "src": "/api/veredito/publish-slug",
      "dest": "/api/veredito/publish-slug.js"
    },
    {
      "src": "/api/veredito/delete",
      "dest": "/api/veredito/delete.js"
    },
    {
      "src": "/api/veredito/preview",
      "dest": "/api/veredito/preview.js"
    },
    {
      "src": "/api/veredito/publish",
      "dest": "/api/veredito/publish.js"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/p/([^/]+)",
      "dest": "/api/veredito/post.js?slug=$1"
    },
    {
      "src": "/rascunho/([^/]+)",
      "dest": "/api/veredito/draft-page.js?slug=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/posts/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "max-image-preview:large"
        }
      ]
    }
  ]
}
